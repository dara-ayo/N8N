    {
      "parameters": {
        "method": "POST",
        "url": "https://www.linkedin.com/oauth/v2/accessToken",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/x-www-form-urlencoded"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "=grant_type=authorization_code&code={{ encodeURIComponent($json.code) }}&redirect_uri={{ encodeURIComponent($json.redirectUri) }}&client_id={{ encodeURIComponent($env.LINKEDIN_CLIENT_ID) }}&client_secret={{ encodeURIComponent($env.LINKEDIN_CLIENT_SECRET) }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          },
          "timeout": 15000
        }
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000004",
      "name": "Exchange LinkedIn Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        700,
        -150
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twitter.com/2/oauth2/token",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/x-www-form-urlencoded"
            },
            {
              "name": "Authorization",
              "value": "=Basic {{ Buffer.from($env.TWITTER_CLIENT_ID + ':' + $env.TWITTER_CLIENT_SECRET).toString('base64') }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "=grant_type=authorization_code&code={{ encodeURIComponent($json.code) }}&redirect_uri={{ encodeURIComponent($json.redirectUri) }}&client_id={{ encodeURIComponent($env.TWITTER_CLIENT_ID) }}&code_verifier={{ encodeURIComponent($json.codeVerifier) }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          },
          "timeout": 15000
        }
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000005",
      "name": "Exchange Twitter Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        700,
        150
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "jsCode": "const tokenResponse = $input.first().json;\nconst oauthInput = $('Validate OAuth Input').first().json;\n\nif (!tokenResponse.access_token) {\n  return [{ json: { error: true, statusCode: 401, message: 'LinkedIn token exchange failed: ' + JSON.stringify(tokenResponse) } }];\n}\n\nconst expiresIn = tokenResponse.expires_in || 5184000; // LinkedIn default: 60 days\nconst expiresAt = new Date(Date.now() + expiresIn * 1000).toISOString();\n\nreturn [{ json: {\n  error: false,\n  platform: 'linkedin',\n  accessToken: tokenResponse.access_token,\n  refreshToken: tokenResponse.refresh_token || null,\n  tokenExpiresAt: expiresAt,\n  scope: tokenResponse.scope || ''\n} }];"
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000006",
      "name": "Parse LinkedIn Token Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        -150
      ]
    },
    {
      "parameters": {
        "jsCode": "const tokenResponse = $input.first().json;\nconst oauthInput = $('Validate OAuth Input').first().json;\n\nif (!tokenResponse.access_token) {\n  return [{ json: { error: true, statusCode: 401, message: 'Twitter token exchange failed: ' + JSON.stringify(tokenResponse) } }];\n}\n\nconst expiresIn = tokenResponse.expires_in || 7200; // Twitter default: 2 hours\nconst expiresAt = new Date(Date.now() + expiresIn * 1000).toISOString();\n\nreturn [{ json: {\n  error: false,\n  platform: 'twitter',\n  accessToken: tokenResponse.access_token,\n  refreshToken: tokenResponse.refresh_token || null,\n  tokenExpiresAt: expiresAt,\n  scope: tokenResponse.scope || ''\n} }];"
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000007",
      "name": "Parse Twitter Token Response",
