  "id": "wf3-oauth-exchange",
  "name": "OAuth Token Exchange",
  "description": "Handles OAuth callbacks from the frontend. Exchanges authorization codes for access tokens (LinkedIn and Twitter/X), fetches user profiles, and stores credentials in Supabase platform_connections table.",
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "oauth-callback",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000001",
      "name": "Receive OAuth Callback",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "webhookId": "oauth-callback-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst errors = [];\n\nif (!body || typeof body !== 'object') {\n  errors.push('Request body is required');\n}\n\nconst platform = (body?.platform || '').toString().trim().toLowerCase();\nconst code = (body?.code || '').toString().trim();\nconst redirectUri = (body?.redirect_uri || body?.redirectUri || '').toString().trim();\nconst codeVerifier = (body?.code_verifier || body?.codeVerifier || '').toString().trim();\n\nif (!['linkedin', 'twitter'].includes(platform)) {\n  errors.push('platform must be \"linkedin\" or \"twitter\"');\n}\n\nif (!code) {\n  errors.push('code (authorization code) is required');\n}\n\nif (!redirectUri) {\n  errors.push('redirect_uri is required');\n}\n\nif (platform === 'twitter' && !codeVerifier) {\n  errors.push('code_verifier is required for Twitter PKCE flow');\n}\n\nif (errors.length > 0) {\n  return [{ json: { error: true, statusCode: 400, message: errors.join('; ') } }];\n}\n\nreturn [{ json: {\n  error: false,\n  platform,\n  code,\n  redirectUri,\n  codeVerifier\n} }];"
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000002",
      "name": "Validate OAuth Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
