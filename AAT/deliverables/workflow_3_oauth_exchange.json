    {
      "parameters": {
        "jsCode": "const profile = $input.first().json;\nconst tokenData = $('Parse LinkedIn Token Response').first().json;\n\nconst platformUserId = profile.sub || profile.id || '';\nconst platformUsername = profile.name || [profile.given_name, profile.family_name].filter(Boolean).join(' ') || profile.email || '';\n\nif (!platformUserId) {\n  return [{ json: { error: true, statusCode: 500, message: 'Could not retrieve LinkedIn user ID from profile' } }];\n}\n\nreturn [{ json: {\n  platform: 'linkedin',\n  accessToken: tokenData.accessToken,\n  refreshToken: tokenData.refreshToken,\n  tokenExpiresAt: tokenData.tokenExpiresAt,\n  platformUserId,\n  platformUsername,\n  profilePicture: profile.picture || null\n} }];"
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000010",
      "name": "Prepare LinkedIn Connection Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        -150
      ]
    },
    {
      "parameters": {
        "jsCode": "const profile = $input.first().json;\nconst tokenData = $('Parse Twitter Token Response').first().json;\n\nconst userData = profile.data || profile;\nconst platformUserId = userData.id || '';\nconst platformUsername = userData.username || userData.name || '';\n\nif (!platformUserId) {\n  return [{ json: { error: true, statusCode: 500, message: 'Could not retrieve Twitter user ID from profile' } }];\n}\n\nreturn [{ json: {\n  platform: 'twitter',\n  accessToken: tokenData.accessToken,\n  refreshToken: tokenData.refreshToken,\n  tokenExpiresAt: tokenData.tokenExpiresAt,\n  platformUserId,\n  platformUsername,\n  profileName: userData.name || null\n} }];"
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000011",
      "name": "Prepare Twitter Connection Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        150
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://your-project.supabase.co/rest/v1/platform_connections",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "on_conflict",
              "value": "platform,platform_user_id"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation,resolution=merge-duplicates"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"platform\": {{ JSON.stringify($json.platform) }},\n  \"access_token\": {{ JSON.stringify($json.accessToken) }},\n  \"refresh_token\": {{ JSON.stringify($json.refreshToken) }},\n  \"token_expires_at\": {{ JSON.stringify($json.tokenExpiresAt) }},\n  \"platform_user_id\": {{ JSON.stringify($json.platformUserId) }},\n  \"platform_username\": {{ JSON.stringify($json.platformUsername) }},\n  \"status\": \"active\",\n  \"connected_at\": {{ JSON.stringify(new Date().toISOString()) }}\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          },
          "timeout": 10000
        }
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000012",
      "name": "Save Connection to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1580,
        0
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "jsCode": "const connectionData = $input.first().json;\nconst platform = connectionData.platform || $('Validate OAuth Input').first().json.platform;\n\n// Try to get username from the connection data or the preparation nodes\nlet username = connectionData.platform_username || '';\nif (!username) {\n  try {\n    if (platform === 'linkedin') {\n      username = $('Prepare LinkedIn Connection Data').first().json.platformUsername;\n    } else {\n      username = $('Prepare Twitter Connection Data').first().json.platformUsername;\n    }\n  } catch(e) {\n    username = 'connected';\n  }\n}\n\nreturn [{ json: {\n  success: true,\n  platform,\n  username,\n  message: `${platform} account connected successfully`\n} }];"
      },
      "id": "c3d4e5f6-3001-4000-9001-000000000013",
