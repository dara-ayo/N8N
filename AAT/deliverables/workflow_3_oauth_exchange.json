      "id": "c3d4e5f6-3001-4000-9001-000000000009",
      "name": "Get Twitter Profile",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1140,
        150
      ],
      "retryOnFail": true,
      "maxTries": 3,
