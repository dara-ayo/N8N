    {
      "parameters": {
        "jsCode": "const adaptedRaw = $('Fetch Adapted Content').first().json;\nconst connectionsRaw = $input.first().json;\nconst publishInput = $('Validate Publish Input').first().json;\n\n// Parse adapted content\nconst adaptedArr = Array.isArray(adaptedRaw) ? adaptedRaw : [adaptedRaw];\nif (!adaptedArr || adaptedArr.length === 0 || !adaptedArr[0].submission_id) {\n  return [{ json: { error: true, statusCode: 404, message: 'No adapted content found for submission ' + publishInput.submissionId } }];\n}\nconst adapted = adaptedArr[0];\n\n// Parse connections\nconst connections = Array.isArray(connectionsRaw) ? connectionsRaw : [connectionsRaw];\nconst connectionMap = {};\nfor (const conn of connections) {\n  if (conn.platform) {\n    connectionMap[conn.platform] = conn;\n  }\n}\n\n// Check which requested platforms have active connections\nconst requestedPlatforms = publishInput.platforms;\nconst readyPlatforms = [];\nconst missingPlatforms = [];\n\nfor (const p of requestedPlatforms) {\n  if (p === 'newsletter') {\n    // Newsletter uses Resend API key from connections or env\n    readyPlatforms.push('newsletter');\n  } else if (connectionMap[p] && connectionMap[p].access_token) {\n    // Check token expiry\n    const expiresAt = connectionMap[p].token_expires_at ? new Date(connectionMap[p].token_expires_at) : null;\n    if (expiresAt && expiresAt < new Date()) {\n      missingPlatforms.push(p + ' (token expired)');\n    } else {\n      readyPlatforms.push(p);\n    }\n  } else {\n    missingPlatforms.push(p + ' (not connected)');\n  }\n}\n\nreturn [{ json: {\n  submissionId: publishInput.submissionId,\n  idempotencyBase: publishInput.idempotencyBase,\n  adapted: {\n    linkedinContent: adapted.linkedin_content || '',\n    twitterContent: adapted.twitter_content || '',\n    newsletterSubject: adapted.newsletter_subject || '',\n    newsletterContent: adapted.newsletter_content || ''\n  },\n  connections: connectionMap,\n  newsletterConnection: connectionMap.newsletter || null,\n  readyPlatforms,\n  missingPlatforms,\n  publishLinkedin: readyPlatforms.includes('linkedin'),\n  publishTwitter: readyPlatforms.includes('twitter'),\n  publishNewsletter: readyPlatforms.includes('newsletter')\n} }];"
      },
