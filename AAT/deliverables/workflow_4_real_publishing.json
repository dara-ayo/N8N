      },
      "id": "d4e5f6a7-4001-4000-9001-000000000001",
      "name": "Receive Publish Request",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "webhookId": "publish-content-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst errors = [];\n\nif (!body || typeof body !== 'object') {\n  errors.push('Request body is required');\n}\n\nconst submissionId = (body?.submission_id || body?.submissionId || '').toString().trim();\nlet platforms = body?.platforms || ['linkedin', 'twitter', 'newsletter'];\n\nif (!submissionId) {\n  errors.push('submission_id is required');\n}\n\nif (!Array.isArray(platforms)) {\n  platforms = [platforms];\n}\n\nconst validPlatforms = ['linkedin', 'twitter', 'newsletter'];\nconst invalidPlatforms = platforms.filter(p => !validPlatforms.includes(p));\nif (invalidPlatforms.length > 0) {\n  errors.push('Invalid platforms: ' + invalidPlatforms.join(', ') + '. Valid: linkedin, twitter, newsletter');\n}\n\nif (errors.length > 0) {\n  return [{ json: { error: true, statusCode: 400, message: errors.join('; ') } }];\n}\n\nconst idempotencyBase = submissionId + '_pub_' + Date.now().toString(36);\n\nreturn [{ json: {\n  error: false,\n  submissionId,\n  platforms,\n  idempotencyBase\n} }];"
      },
