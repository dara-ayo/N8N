  "id": "wf4-real-publishing",
  "name": "Real Platform Publishing",
  "description": "Standalone publishing workflow. Fetches adapted content and platform credentials from Supabase, publishes to LinkedIn, Twitter/X, and sends newsletter via Resend. Each platform publishes independently so one failure does not block others.",
  "active": true,
  "isArchived": false,
