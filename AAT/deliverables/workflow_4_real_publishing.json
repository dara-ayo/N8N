      "id": "d4e5f6a7-4001-4000-9001-000000000017",
      "name": "Newsletter Skipped",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1340,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "const publishData = $('Prepare Publishing Data').first().json;\n\n// Collect results from all paths\nconst results = [];\nconst platformsPublished = [];\nconst errors = [];\n\n// Helper to safely get a result from a node\nfunction getResult(nodeName) {\n  try {\n    return $(nodeName).first().json;\n  } catch(e) {\n    return null;\n  }\n}\n\n// LinkedIn result\nconst linkedinResult = getResult('Handle LinkedIn Result') || getResult('LinkedIn Skipped');\nif (linkedinResult) {\n  results.push(linkedinResult);\n  if (linkedinResult.success) platformsPublished.push('linkedin');\n  else if (linkedinResult.error) errors.push({ platform: 'linkedin', error: linkedinResult.error });\n}\n\n// Twitter result\nconst twitterResult = getResult('Handle Twitter Result') || getResult('Twitter Skipped');\nif (twitterResult) {\n  results.push(twitterResult);\n  if (twitterResult.success) platformsPublished.push('twitter');\n  else if (twitterResult.error) errors.push({ platform: 'twitter', error: twitterResult.error });\n}\n\n// Newsletter result\nconst newsletterResult = getResult('Handle Newsletter Result') || getResult('Newsletter Skipped');\nif (newsletterResult) {\n  results.push(newsletterResult);\n  if (newsletterResult.success) platformsPublished.push('newsletter');\n  else if (newsletterResult.error) errors.push({ platform: 'newsletter', error: newsletterResult.error });\n}\n\nconst overallSuccess = platformsPublished.length > 0;\nconst status = overallSuccess ? 'published' : 'publish_failed';\n\nreturn [{ json: {\n  submissionId: publishData.submissionId,\n  success: overallSuccess,\n  status,\n  platformsPublished,\n  errors,\n  results,\n  publishedAt: overallSuccess ? new Date().toISOString() : null\n} }];"
      },
