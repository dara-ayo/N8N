        "jsCode": "const results = $('Aggregate Publishing Results').first().json;\n\nreturn [{ json: {\n  success: results.success,\n  submission_id: results.submissionId,\n  status: results.status,\n  platforms_published: results.platformsPublished,\n  errors: results.errors,\n  published_at: results.publishedAt,\n  message: results.success\n    ? 'Content published to: ' + results.platformsPublished.join(', ')\n    : 'Publishing failed for all platforms. See errors for details.'\n} }];"
