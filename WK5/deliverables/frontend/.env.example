# Airtable Personal Access Token (or API Key)
# Find it at: https://airtable.com/create/tokens
VITE_AIRTABLE_API_KEY=

# Airtable Base ID
# Open your base in Airtable, go to https://airtable.com/developers/web/api/introduction
# Select your base — the Base ID starts with "app" (e.g., appXXXXXXXXXXXXXX)
VITE_AIRTABLE_BASE_ID=

# n8n Webhook URL for triggering the lead-gen pipeline
# Default: http://localhost:5678/webhook/wk5-lead-gen
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/wk5-lead-gen
